# WhatsApp AI Bot — Environment Variables

# ─── Gemini API ──────────────────────────────────────────────────────────────
# Get your free API key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: override the default model (default: gemini-2.0-flash)
# When gemini-2.0-flash-preview becomes available via SDK, set it here:
# GEMINI_MODEL=gemini-2.0-flash-preview
GEMINI_MODEL=gemini-2.0-flash

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=3001
